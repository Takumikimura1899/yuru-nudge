# Supabase（ローカルは `supabase status` の値、本番は Supabase ダッシュボードから）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Kysely / kysely-codegen 用の PostgreSQL 接続文字列
# ローカル例: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# AI（Phase 2 以降で必須）
GOOGLE_GENERATIVE_AI_API_KEY=

# MVP は固定ユーザーID。Bearer トークンで Server Function を保護
APP_USER_ID=
API_SECRET_KEY=
