{
  "name": "yuru-nudge",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run db:up && vp dev --port 3000",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "check": "vp check --fix",
    "deploy": "bun run build && wrangler deploy",
    "db:up": "mise exec -- supabase start",
    "db:down": "mise exec -- supabase stop",
    "db:gen": "kysely-codegen --dialect postgres --include-pattern 'public.*' --env-file=.env.local --out-file src/server/db-types.ts",
    "db:reset": "mise exec -- supabase db reset",
    "db:migrate:new": "mise exec -- supabase migration new",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@supabase/supabase-js": "^2.105.3",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.167.33",
    "ai": "^6.0.197",
    "kysely": "^0.28.17",
    "kysely-postgres-js": "^3.0.0",
    "lucide-react": "^0.545.0",
    "motion": "^12.42.2",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^28.1.0",
    "kysely-codegen": "^0.20.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
